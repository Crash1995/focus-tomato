{
  "name": "focusforge",
  "version": "0.1.0",
  "description": "Native-feeling macOS Pomodoro timer with gamification and AI daily summaries.",
  "main": "src/main.js",
  "type": "commonjs",
  "author": "FocusForge",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "electron src/main.js",
    "build:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "41.2.0",
    "electron-builder": "26.8.1"
  },
  "build": {
    "appId": "com.focusforge.app",
    "productName": "FocusForge",
    "electronDist": "node_modules/electron/dist",
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": "dmg"
    },
    "dmg": {
      "title": "FocusForge",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
